'builtin' 'local' '-a' 'p10k_config_opts'
[[ ! -o 'aliases'         ]] || p10k_config_opts+=('aliases')
[[ ! -o 'sh_glob'         ]] || p10k_config_opts+=('sh_glob')
[[ ! -o 'no_brace_expand' ]] || p10k_config_opts+=('no_brace_expand')
'builtin' 'setopt' 'no_aliases' 'no_sh_glob' 'brace_expand'

() {
  emulate -L zsh -o extended_glob

  [[ $ZSH_VERSION == (5.<1->*|<6->.*) ]] || return

  typeset -g ink='#f7f9ff'
  typeset -g muted='#a7b6d6'
  typeset -g glass='#9be8ff'
  typeset -g glass_hi='#26375f'
  typeset -g glass_low='#1d2741'
  typeset -g cyan='#06222c'
  typeset -g violet='#be98ff'
  typeset -g capsule_dark='#06222c'
  typeset -g capsule_dir='#9be8ff'
  typeset -g capsule_violet='#be98ff'
  typeset -g capsule_indigo='#7285ff'
  typeset -g capsule_meta='#26375f'
  typeset -g capsule_meta_alt='#1d2741'
  typeset -g green='#8fffd2'
  typeset -g yellow='#fde047'
  typeset -g amber='#fbbf24'
  typeset -g blue='#60a5fa'
  typeset -g rose='#f472b6'
  typeset -g red='#fb7185'
  typeset -g slate='#111827'

  typeset -g POWERLEVEL9K_DISABLE_CONFIGURATION_WIZARD=true
  typeset -g POWERLEVEL9K_MODE=nerdfont-v3
  typeset -g POWERLEVEL9K_ICON_PADDING=none
  typeset -g POWERLEVEL9K_PROMPT_ADD_NEWLINE=false
  typeset -g POWERLEVEL9K_TRANSIENT_PROMPT=always
  typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

  typeset -g POWERLEVEL9K_LEFT_PROMPT_ELEMENTS=(
    context
    dir
    project_persona
    vcs
    newline
    prompt_char
    capsule_prompt_label
  )

  typeset -g POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(
    swift_runtime
    docker_env
    time
  )

  typeset -g POWERLEVEL9K_LEFT_SEGMENT_SEPARATOR=' '
  typeset -g POWERLEVEL9K_RIGHT_SEGMENT_SEPARATOR=' '
  typeset -g POWERLEVEL9K_LEFT_SUBSEGMENT_SEPARATOR=' '
  typeset -g POWERLEVEL9K_RIGHT_SUBSEGMENT_SEPARATOR=' '
  typeset -g POWERLEVEL9K_LEFT_PROMPT_FIRST_SEGMENT_START_SYMBOL=''
  typeset -g POWERLEVEL9K_LEFT_PROMPT_LAST_SEGMENT_END_SYMBOL=''
  typeset -g POWERLEVEL9K_RIGHT_PROMPT_FIRST_SEGMENT_START_SYMBOL=''
  typeset -g POWERLEVEL9K_RIGHT_PROMPT_LAST_SEGMENT_END_SYMBOL=''
  typeset -g POWERLEVEL9K_EMPTY_LINE_LEFT_PROMPT_FIRST_SEGMENT_END_SYMBOL=
  typeset -g POWERLEVEL9K_EMPTY_LINE_RIGHT_PROMPT_FIRST_SEGMENT_START_SYMBOL=
  typeset -g POWERLEVEL9K_MULTILINE_FIRST_PROMPT_PREFIX=
  typeset -g POWERLEVEL9K_MULTILINE_NEWLINE_PROMPT_PREFIX=
  typeset -g POWERLEVEL9K_MULTILINE_LAST_PROMPT_PREFIX=
  typeset -g POWERLEVEL9K_MULTILINE_FIRST_PROMPT_SUFFIX=
  typeset -g POWERLEVEL9K_MULTILINE_NEWLINE_PROMPT_SUFFIX=
  typeset -g POWERLEVEL9K_MULTILINE_LAST_PROMPT_SUFFIX=

  typeset -g POWERLEVEL9K_CONTEXT_DEFAULT_FOREGROUND=$muted
  typeset -g POWERLEVEL9K_CONTEXT_DEFAULT_BACKGROUND=
  typeset -g POWERLEVEL9K_CONTEXT_ROOT_FOREGROUND=$red
  typeset -g POWERLEVEL9K_CONTEXT_ROOT_BACKGROUND=
  typeset -g POWERLEVEL9K_CONTEXT_TEMPLATE='%n@%m'
  typeset -g POWERLEVEL9K_ALWAYS_SHOW_CONTEXT=false
  typeset -g POWERLEVEL9K_CONTEXT_{DEFAULT,ROOT}_{LEFT,RIGHT}_WHITESPACE=

  typeset -g POWERLEVEL9K_DIR_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_DIR_BACKGROUND=$glass
  typeset -g POWERLEVEL9K_DIR_SHORTENED_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_DIR_ANCHOR_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_SHORTEN_STRATEGY=truncate_to_unique
  typeset -g POWERLEVEL9K_SHORTEN_DIR_LENGTH=100
  typeset -g POWERLEVEL9K_DIR_TRUNCATE_BEFORE_MARKER=false
  typeset -g POWERLEVEL9K_DIR_SHOW_WRITABLE=v3
  typeset -g POWERLEVEL9K_DIR_LEFT_PROMPT_FIRST_SEGMENT_START_SYMBOL=''
  typeset -g POWERLEVEL9K_DIR_LEFT_PROMPT_LAST_SEGMENT_END_SYMBOL=''
  typeset -g POWERLEVEL9K_DIR_VISUAL_IDENTIFIER_EXPANSION=''
  typeset -g POWERLEVEL9K_HOME_FOLDER_ABBREVIATION='~'
  typeset -g POWERLEVEL9K_DIR_CLASSES=(
    '~'                                  DIRECTORY
    '~/Documents(|/*)'                   docs
    '~/Downloads(|/*)'                   dl
    '~/Desktop(|/*)'                     desk
    '~/Library(|/*)'                     lib
    '*/Projects(|/*)'                    proj
    '*/xCode_Projects(|/*)'              xcode
  )
  typeset -g POWERLEVEL9K_DIR_DOCS_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_DIR_DOCS_BACKGROUND=$glass
  typeset -g POWERLEVEL9K_DIR_DOCS_VISUAL_IDENTIFIER_EXPANSION=''
  typeset -g POWERLEVEL9K_DIR_DL_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_DIR_DL_BACKGROUND=$glass
  typeset -g POWERLEVEL9K_DIR_DL_VISUAL_IDENTIFIER_EXPANSION=''
  typeset -g POWERLEVEL9K_DIR_DESK_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_DIR_DESK_BACKGROUND=$glass
  typeset -g POWERLEVEL9K_DIR_DESK_VISUAL_IDENTIFIER_EXPANSION=''
  typeset -g POWERLEVEL9K_DIR_LIB_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_DIR_LIB_BACKGROUND=$glass
  typeset -g POWERLEVEL9K_DIR_LIB_VISUAL_IDENTIFIER_EXPANSION=''
  typeset -g POWERLEVEL9K_DIR_PROJ_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_DIR_PROJ_BACKGROUND=$glass
  typeset -g POWERLEVEL9K_DIR_PROJ_VISUAL_IDENTIFIER_EXPANSION=''
  typeset -g POWERLEVEL9K_DIR_XCODE_FOREGROUND=$capsule_dark
  typeset -g POWERLEVEL9K_DIR_XCODE_BACKGROUND=$glass
  typeset -g POWERLEVEL9K_DIR_XCODE_VISUAL_IDENTIFIER_EXPANSION=''

  typeset -g POWERLEVEL9K_VCS_CLEAN_FOREGROUND='#ffffff'
  typeset -g POWERLEVEL9K_VCS_CLEAN_BACKGROUND=$capsule_indigo
  typeset -g POWERLEVEL9K_VCS_MODIFIED_FOREGROUND='#fef08a'
  typeset -g POWERLEVEL9K_VCS_MODIFIED_BACKGROUND=$capsule_meta_alt
  typeset -g POWERLEVEL9K_VCS_UNTRACKED_FOREGROUND='#fef08a'
  typeset -g POWERLEVEL9K_VCS_UNTRACKED_BACKGROUND=$capsule_meta_alt
  typeset -g POWERLEVEL9K_VCS_CONFLICTED_FOREGROUND='#fda4af'
  typeset -g POWERLEVEL9K_VCS_CONFLICTED_BACKGROUND=$rose
  typeset -g POWERLEVEL9K_VCS_LOADING_FOREGROUND=$muted
  typeset -g POWERLEVEL9K_VCS_LOADING_BACKGROUND=$capsule_meta_alt
  typeset -g POWERLEVEL9K_VCS_VISUAL_IDENTIFIER_EXPANSION=''
  typeset -g POWERLEVEL9K_VCS_BRANCH_ICON=
  typeset -g POWERLEVEL9K_VCS_GIT_HOOKS=(vcs-detect-changes git-untracked git-aheadbehind)
  typeset -g POWERLEVEL9K_VCS_DISABLE_GITSTATUS_FORMATTING=false
  typeset -g POWERLEVEL9K_VCS_CONTENT_EXPANSION=' ${P9K_CONTENT} '

  typeset -g POWERLEVEL9K_STATUS_EXTENDED_STATES=true
  typeset -g POWERLEVEL9K_STATUS_OK=false
  typeset -g POWERLEVEL9K_STATUS_ERROR_FOREGROUND='#fff7fb'
  typeset -g POWERLEVEL9K_STATUS_ERROR_BACKGROUND=$rose
  typeset -g POWERLEVEL9K_STATUS_ERROR_VISUAL_IDENTIFIER_EXPANSION='✘'
  typeset -g POWERLEVEL9K_STATUS_ERROR_CONTENT_EXPANSION=' ${P9K_CONTENT} '
  typeset -g POWERLEVEL9K_STATUS_OK_IN_NON_VERBOSE=false

  typeset -g POWERLEVEL9K_BACKGROUND_JOBS_VERBOSE=false
  typeset -g POWERLEVEL9K_BACKGROUND_JOBS_FOREGROUND='#c6dbff'
  typeset -g POWERLEVEL9K_BACKGROUND_JOBS_BACKGROUND=$capsule_meta_alt
  typeset -g POWERLEVEL9K_BACKGROUND_JOBS_VISUAL_IDENTIFIER_EXPANSION=''
  typeset -g POWERLEVEL9K_BACKGROUND_JOBS_CONTENT_EXPANSION=' ${P9K_CONTENT} '

  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_THRESHOLD=1
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_PRECISION=0
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_FOREGROUND='#c6dbff'
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_BACKGROUND=$capsule_meta_alt
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_VISUAL_IDENTIFIER_EXPANSION='󰔛'
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_CONTENT_EXPANSION=' ${P9K_COMMAND_DURATION} '

  typeset -g POWERLEVEL9K_TIME_FOREGROUND='#c6dbff'
  typeset -g POWERLEVEL9K_TIME_BACKGROUND=$capsule_meta_alt
  typeset -g POWERLEVEL9K_TIME_FORMAT='%D{%H:%M}'
  typeset -g POWERLEVEL9K_TIME_VISUAL_IDENTIFIER_EXPANSION=
  typeset -g POWERLEVEL9K_TIME_CONTENT_EXPANSION=' ${P9K_CONTENT} '

  typeset -g POWERLEVEL9K_AWS_FOREGROUND=$slate
  typeset -g POWERLEVEL9K_AWS_BACKGROUND=$amber
  typeset -g POWERLEVEL9K_AWS_VISUAL_IDENTIFIER_EXPANSION='☁'
  typeset -g POWERLEVEL9K_AWS_CONTENT_EXPANSION=' ${P9K_AWS_PROFILE//\%/%%} '

  typeset -g POWERLEVEL9K_KUBECONTEXT_FOREGROUND=$slate
  typeset -g POWERLEVEL9K_KUBECONTEXT_BACKGROUND=$blue
  typeset -g POWERLEVEL9K_KUBECONTEXT_VISUAL_IDENTIFIER_EXPANSION='☸'
  typeset -g POWERLEVEL9K_KUBECONTEXT_SHOW_DEFAULT_NAMESPACE=false
  typeset -g POWERLEVEL9K_KUBECONTEXT_CONTENT_EXPANSION=' ${P9K_KUBECONTEXT_CLOUD_CLUSTER:-${P9K_KUBECONTEXT_NAME//\%/%%}}${${P9K_KUBECONTEXT_NAMESPACE:#default}:+ (${P9K_KUBECONTEXT_NAMESPACE//\%/%%})} '

  typeset -g POWERLEVEL9K_DIRENV_FOREGROUND=$muted
  typeset -g POWERLEVEL9K_DIRENV_BACKGROUND=$capsule_meta_alt
  typeset -g POWERLEVEL9K_DIRENV_VISUAL_IDENTIFIER_EXPANSION='direnv'
  typeset -g POWERLEVEL9K_DIRENV_CONTENT_EXPANSION=' ${P9K_CONTENT} '

  typeset -g POWERLEVEL9K_PROMPT_CHAR_BACKGROUND=
  typeset -g POWERLEVEL9K_PROMPT_CHAR_OK_VIINS_FOREGROUND=$green
  typeset -g POWERLEVEL9K_PROMPT_CHAR_ERROR_VIINS_FOREGROUND=$red
  typeset -g POWERLEVEL9K_PROMPT_CHAR_OK_VICMD_FOREGROUND=$yellow
  typeset -g POWERLEVEL9K_PROMPT_CHAR_ERROR_VICMD_FOREGROUND=$yellow
  typeset -g POWERLEVEL9K_PROMPT_CHAR_OK_VIINS_CONTENT_EXPANSION='❯'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_ERROR_VIINS_CONTENT_EXPANSION='❯'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_OK_VICMD_CONTENT_EXPANSION='❮'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_ERROR_VICMD_CONTENT_EXPANSION='❮'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_LEFT_PROMPT_FIRST_SEGMENT_START_SYMBOL=
  typeset -g POWERLEVEL9K_PROMPT_CHAR_LEFT_PROMPT_LAST_SEGMENT_END_SYMBOL=
  typeset -g POWERLEVEL9K_PROMPT_CHAR_LEFT_{LEFT,RIGHT}_WHITESPACE=

  prompt_project_persona() {
    emulate -L zsh -o extended_glob

    local persona=
    if [[ -f Package.swift ]] || [[ -n *.xcodeproj(N) ]] || [[ -n *.xcworkspace(N) ]]; then
      persona='Swift'
    elif [[ -f package.json ]]; then
      if [[ -d backend || -d api || -f server.js || -f server.ts ]]; then
        persona='Node API'
      else
        persona='Node App'
      fi
    elif [[ -f pyproject.toml || -f requirements.txt || -f Pipfile ]]; then
      persona='Python'
    fi

    [[ -n "$persona" ]] || return
    p10k segment -f '#ffffff' -b $capsule_violet -t " $persona "
  }

  prompt_capsule_prompt_label() {
    p10k segment -f $muted -t ' CAPSULE REFINED'
  }

  prompt_node_runtime() {
    emulate -L zsh -o extended_glob
    [[ -f package.json || -f .node-version || -f .nvmrc || -d node_modules ]] || return
    (( $+commands[node] )) || return

    local version
    version=$(node -v 2>/dev/null) || return
    [[ -n "$version" ]] || return
    p10k segment -i '⬢' -f '#c6dbff' -b $capsule_meta -t " ${version#v} "
  }

  prompt_python_runtime() {
    emulate -L zsh -o extended_glob
    [[ -f pyproject.toml || -f requirements.txt || -f Pipfile || -f .python-version || -d .venv || -d venv ]] || return
    (( $+commands[python3] )) || return

    local version
    version=$(python3 --version 2>/dev/null) || return
    version=${version##* }
    [[ -n "$version" ]] || return
    p10k segment -i '' -f '#c6dbff' -b $capsule_meta -t " $version "
  }

  prompt_swift_runtime() {
    emulate -L zsh -o extended_glob
    [[ -f Package.swift || -n *.xcodeproj(N) || -n *.xcworkspace(N) ]] || return
    (( $+commands[swift] )) || return

    local version
    version=$(swift --version 2>/dev/null | awk 'NR==1 {for (i=1; i<=NF; ++i) if ($i == "version") {print $(i+1); exit}}')
    [[ -n "$version" ]] || return
    p10k segment -f '#c6dbff' -b $capsule_meta -t " $version "
  }

  prompt_docker_env() {
    emulate -L zsh -o extended_glob
    (( $+commands[docker] )) || return

    local context
    context=$(docker context show 2>/dev/null) || return
    [[ -n "$context" ]] || return
    p10k segment -f '#c6dbff' -b $capsule_meta -t " $context "
  }

  prompt_mise_env() {
    emulate -L zsh -o extended_glob
    [[ -f .mise.toml || -f mise.toml || -f .tool-versions ]] || return
    (( $+commands[mise] )) || return

    p10k segment -f '#c6dbff' -b $capsule_meta_alt -t ' mise '
  }

  prompt_danger_context() {
    local value="${AWS_PROFILE:-} ${KUBECONFIG:-} ${NODE_ENV:-} ${VERCEL_ENV:-} ${ENVIRONMENT:-} ${ENV:-}"
    case "$value" in
      *prod*|*Prod*|*PROD*|*production*|*Production*|*main*)
        p10k segment -f '#fff7fb' -b $rose -t ' PROD '
        ;;
      *staging*|*stage*|*preview*)
        p10k segment -f '#1a1d24' -b $yellow -t ' STAGE '
        ;;
    esac
  }
}

(( ! $#p10k_config_opts )) || setopt "${p10k_config_opts[@]}"
'builtin' 'unset' 'p10k_config_opts'
